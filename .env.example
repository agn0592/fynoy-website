# Copy to .env.local and fill in real values. Do not commit .env.local.

# ── Supabase ────────────────────────────────────────────
# Project URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key: same panel, "anon public" row
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: same panel, "service_role" row. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude API) ──────────────────────────────
# Used by /api/commentary/generate and /api/cases/summary
ANTHROPIC_API_KEY=

# ── IBKR Flex Web Service ───────────────────────────────
# IBKR Client Portal → Reports → Flex Web Service → Configure
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
# Shared secret for the Make.com / cron trigger of /api/ibkr/sync
# and /api/commentary/generate. Anything random, 32+ chars.
IBKR_SYNC_SECRET=

# ── Site URL ────────────────────────────────────────────
# Production override; defaults to https://fynoy.com if unset.
NEXT_PUBLIC_SITE_URL=https://fynoy.com

# ── Resend (used by Supabase Auth SMTP — set in Supabase Dashboard, not here) ──
# RESEND_API_KEY is not used by app code today; configure in Supabase
# Dashboard → Auth → SMTP Settings instead.
